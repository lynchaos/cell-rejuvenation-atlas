// Machine-local overrides for small hosts (e.g. 8 GB Raspberry Pi).
// The default label memories (16/64 GB) exceed physical RAM and Nextflow
// refuses to submit such tasks on the local executor. Actual usage stays
// well below these caps for the processed-matrix analyses.
process {
    withLabel: low     { cpus = 2; memory = '3 GB' }
    withLabel: medium  { cpus = 4; memory = '6 GB' }
    withLabel: highmem { cpus = 4; memory = '7 GB' }
    withLabel: gpu     { cpus = 4; memory = '6 GB' }
}
