// AWS Batch profile
// Prerequisites (one-time setup, see docs/aws_setup.md):
//   1. Batch compute environment + job queue (spot, g4dn for gpu-labeled jobs)
//   2. S3 bucket for the work directory
//   3. ECR repository with the pipeline container
// Then:
//   nextflow run main.nf -profile awsbatch -bucket-dir s3://YOUR-BUCKET/scratch

aws {
    region = 'eu-west-2'
    batch {
        maxParallelTransfers = 8
    }
}

process {
    executor       = 'awsbatch'
    queue          = 'rejuvenation-atlas-queue'
    container      = 'ghcr.io/lynchaos/cell-rejuvenation-atlas:848c8b1'
    errorStrategy  = 'retry'
    maxRetries     = 3

    withLabel: gpu {
        queue = 'rejuvenation-atlas-gpu-queue'
    }
}

env.PYTHONPATH = '/opt/atlas'

workDir = 's3://cell-rejuvenation-atlas-893223317248/work'

params {
    outdir  = 's3://cell-rejuvenation-atlas-893223317248/results'
    datadir = 's3://cell-rejuvenation-atlas-893223317248/data'
}

// AWS SDK handles S3 I/O; no AWS CLI or Fusion needed in container.
wave { enabled = false }
fusion { enabled = false }
tower { enabled = false }
