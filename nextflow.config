// Cell Rejuvenation Atlas — Nextflow configuration

params {
    module      = 'all'
    outdir      = 'results'
    datadir     = 'data'
    from_fastq  = false
    clock_coef  = null
    sasp_design = null
    max_epochs  = 400
}

process {
    errorStrategy = 'retry'
    maxRetries    = 2

    withLabel: low     { cpus = 2;  memory = '4 GB'  }
    withLabel: medium  { cpus = 4;  memory = '16 GB' }
    withLabel: highmem { cpus = 8;  memory = '64 GB' }
    withLabel: gpu     { cpus = 8;  memory = '32 GB'; accelerator = 1 }
}

env.PYTHONPATH = "$projectDir"

profiles {

    local {
        process.executor = 'local'
    }

    docker {
        docker.enabled     = true
        process.container  = 'ghcr.io/lynchaos/cell-rejuvenation-atlas:latest'
    }

    test {
        // CI smoke-test profile: runs pipeline code on bundled synthetic data
        docker.enabled    = false
        process.executor  = 'local'
        params.module     = 'all'
        params.datadir    = 'data/test'
        params.max_epochs = 2
        process.beforeScript = "export PATH=\"$projectDir/.venv/bin:\$PATH\""
    }

    awsbatch {
        includeConfig 'conf/awsbatch.config'
    }
}

manifest {
    name        = 'cell-rejuvenation-atlas'
    description = 'Reproducible multi-omics reanalysis of aging, reprogramming and rejuvenation data'
    version     = '0.1.0'
    nextflowVersion = '>=23.04.0'
}
